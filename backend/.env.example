# Neo4j
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=neo4j

# Google AI (Gemini)
GOOGLE_API_KEY=your-google-api-key

# Embeddings (default: all-mpnet-base-v2, 768-dim, retrieval-optimized)
# DISTILBERT_MODEL=all-mpnet-base-v2
# EMBEDDING_BATCH_SIZE=50
# Note: Changing DISTILBERT_MODEL requires re-embedding existing nodes (run embed_nodes or re-ingest)

# Ingestion (Module 1)
# INGESTION_ON_ERROR=RAISE
# INGESTION_LLM_MAX_RETRIES=5
# INGESTION_LLM_BASE_DELAY=5

# Optional: Aura Agent (Module 3)
# AURA_AGENT_ENDPOINT=https://api.neo4j.io/.../invoke
# AURA_CLIENT_ID=your-client-id
# AURA_CLIENT_SECRET=your-client-secret
# AURA_TOKEN_URL=https://api.neo4j.io/oauth/token
# AURA_AGENT_MAX_RETRIES=3
# AURA_AGENT_RETRY_BACKOFF=1.0

# Framework branding (consumer-specific)
# API_TITLE=Knowledge Graph Framework API
# SYNTHESIS_PERSONA=Analytical Consultant
# SYNTHESIS_FRAMEWORK_NAME=
# LOGGER_NAME=kg-framework
# SESSION_PREFIX=session_

# CompGCN audit (regularization, early stopping)
# COMPGCN_EPOCHS=50
# COMPGCN_PATIENCE=10
# COMPGCN_DROPOUT=0.3
# COMPGCN_LABEL_SMOOTHING=0.1
# COMPGCN_GRAD_CLIP=1.0
# COMPGCN_NEG_RATIO=3

# Optional: API tuning
# PORT=8000
# CORS_ORIGINS=http://localhost:3000
# UPLOAD_MAX_SIZE_MB=50
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW_SEC=60
# PREFER_LOCAL_GRAPH=true
# GROUNDING_MIN_SCORE=0.95

# --- The Remembrance consumer overrides (copy to .env when using this frontend) ---
# API_TITLE=The Remembrance Framework API
# SYNTHESIS_PERSONA=Lead Investigative Analyst
# SYNTHESIS_FRAMEWORK_NAME=The Remembrance
