# =============================================================================
# The Remembrance Vault — Environment Configuration
# Copy this file to `backend/.env` and fill in the required values.
# Values shown are the Run 8 (defense-recommended) defaults unless noted.
# =============================================================================


# --- REQUIRED ----------------------------------------------------------------

# Neo4j Aura (or self-hosted)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=neo4j

# Google AI (Gemini)
GOOGLE_API_KEY=your-google-api-key


# --- SECURITY / DEPLOYMENT ---------------------------------------------------

# Admin token required to call POST /reset (graph wipe). UNSET = the endpoint
# default-denies. To allow unauthenticated /reset on a local dev box, set
# RESET_ALLOW_UNAUTHENTICATED=true (NEVER do this in production).
# ADMIN_API_KEY=replace-with-a-long-random-string
# RESET_ALLOW_UNAUTHENTICATED=false

# Comma-separated list of allowed origins for browser requests.
# Default is `*` which is REJECTED at startup when DEBUG=false (since `*` is
# unsafe with allow_credentials=True). Set explicit origins for production.
CORS_ORIGINS=http://localhost:3000
DEBUG=false
PORT=8000
UPLOAD_MAX_SIZE_MB=50
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SEC=60


# --- BRANDING ----------------------------------------------------------------

API_TITLE=The Remembrance Framework API
FRONTEND_APP_NAME=The Remembrance Vault
SYNTHESIS_PERSONA=Lead Investigative Analyst
SYNTHESIS_FRAMEWORK_NAME=The Remembrance
LOGGER_NAME=remembrance
SESSION_PREFIX=session_
SHOW_DASHBOARD_STATS=true


# --- LLM / EMBEDDING ---------------------------------------------------------

GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_PROVIDER=distilbert
DISTILBERT_MODEL=distilbert-base-nli-stsb-mean-tokens
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=50


# --- INGESTION ---------------------------------------------------------------

# RAISE: fail loudly on extraction errors. IGNORE: log + continue.
INGESTION_ON_ERROR=RAISE
INGESTION_LLM_MAX_RETRIES=5
INGESTION_LLM_BASE_DELAY=5


# --- SCHEMA ------------------------------------------------------------------
# These were originally designed for academic-paper corpora and are
# deliberately re-used here as a domain-agnostic schema. Override for
# domain-specific extraction.

LEGAL_NODE_TYPES=__Entity__,Entity,Method,Researcher,Dataset,Concept,Result,Metric
LEGAL_RELATIONSHIP_TYPES=USES,CONTRADICTS,EXTENDS,PROPOSES,EVALUATES,ACHIEVES,FROM_CHUNK
SOURCE_DOCUMENT_LABEL=SourceDocument
INGESTION_RUN_LABEL=IngestionRun
AUDIT_RUN_LABEL=AuditRun
GRAPH_READY_MIN_PROVENANCE_LINKS=1


# --- COMPGCN AUDIT (Run 8 defense config) ------------------------------------
# These are the values the paper v6.4 reports under the recommended Run 8
# configuration. Override only if you are running a new ablation.

# Architecture
COMPGCN_HIDDEN_CHANNELS=256
COMPGCN_DROPOUT=0.2
COMPGCN_LABEL_SMOOTHING=0.05
COMPGCN_GRAD_CLIP=1.0
COMPGCN_SEED=42

# Training
COMPGCN_EPOCHS=300
COMPGCN_LEARNING_RATE=0.0005
COMPGCN_WEIGHT_DECAY=0.0001
COMPGCN_PATIENCE=30
COMPGCN_VALIDATION_SPLIT=0.2

# Negative sampling
COMPGCN_NEG_RATIO=15
COMPGCN_NEG_SAMPLING=uniform
# Run 7 confirmed type_aware does not lift MRR on this corpus
# (54% Concept skew). Keep uniform unless re-investigating.

# Loss (BPR + self-adversarial — Run 8 winner)
COMPGCN_LOSS=bpr
COMPGCN_BPR_MARGIN=0.0
COMPGCN_ADV_TEMP=1.0
# COMPGCN_LOSS=bce          # BCEWithLogits baseline (Run 6)
# COMPGCN_ADV_TEMP=0.0      # Disable self-adv weighting

# Decoder (DistMult — Run 8 winner. Run 9 showed RotatE regresses on this corpus.)
COMPGCN_DECODER=distmult
# COMPGCN_DECODER=rotate    # RotatE phase-rotation decoder

# Guardrail: skip Neo4j score write-back if the trained model scores below this.
# Prevents a regressed model from clobbering production plausibility values.
COMPGCN_AUC_GUARDRAIL=0.95


# --- INFERENCE ---------------------------------------------------------------

# Plausibility threshold τ: triplets below this are filtered out before
# synthesis. The paper's canonical value is 0.95.
GROUNDING_MIN_SCORE=0.95

# Retrieval limits
RETRIEVAL_SEED_LIMIT=100
RETRIEVAL_EXPANSION_LIMIT=25
LEIDEN_RESOLUTION=1.0


# --- EVALUATION --------------------------------------------------------------

# Path to the query set. Defaults to backend/evaluation_queries.json.
# Switch to evaluation_queries_legal.json for corpus-aligned legal queries.
# EVALUATION_QUERIES_FILE=evaluation_queries_legal.json
# EVALUATION_RESULTS_PATH=evaluation_results.json

# Max concurrent evaluation pipelines (synth + grounding judge + faithfulness
# judge per query). Lower if you hit Gemini's per-minute rate limit.
# EVALUATION_MAX_CONCURRENCY=3

# Paper-aligned defense targets (used by /config endpoint to compute pass flags)
TARGET_AUC_ROC=0.95
TARGET_MRR=0.95
TARGET_GROUNDING=0.98
